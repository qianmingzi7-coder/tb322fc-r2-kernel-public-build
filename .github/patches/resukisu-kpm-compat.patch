+#endif
+DYNAMIC_STRUCT_END(mnt_namespace)
+
+#ifdef CONFIG_KPROBES
+DYNAMIC_STRUCT_BEGIN(kprobe)
+DEFINE_MEMBER(kprobe, addr)
+DEFINE_MEMBER(kprobe, symbol_name)
